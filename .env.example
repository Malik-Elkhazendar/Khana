# ===========================================
# Khana Environment Configuration
# ===========================================
# Copy this file to .env and update values
# NEVER commit .env to version control

# Database Configuration
POSTGRES_USER=khana
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=khana_dev
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Connection URL (for TypeORM/NestJS)
DATABASE_URL=postgresql://khana:change_me_in_production@localhost:5432/khana_dev

# API Configuration
API_PORT=3000
API_PREFIX=api

# Frontend Configuration
FRONTEND_PORT=4200
