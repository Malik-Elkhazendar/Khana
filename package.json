{
  "name": "@khana/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "db:connect": "docker exec -it khana-postgres psql -U khana -d khana_dev",
    "build": "nx run-many -t build",
    "build:all": "nx run-many -t build --all",
    "test": "nx run-many -t test",
    "test:all": "nx run-many -t test --all",
    "test:watch": "nx run-many -t test --watch",
    "lint": "nx run-many -t lint",
    "lint:all": "nx run-many -t lint --all",
    "lint:fix": "nx run-many -t lint --fix",
    "check": "nx run-many -t lint test build",
    "check:all": "nx run-many -t lint test build --all",
    "audit:structure": "node tools/architecture/audit-structure.mjs",
    "audit:comments": "node tools/architecture/audit-comments.mjs",
    "audit:entrypoints": "node tools/architecture/audit-entrypoints.mjs",
    "audit:entrypoints:check": "node tools/architecture/audit-entrypoints.mjs --fail-on-findings",
    "audit:hotspots": "node tools/architecture/audit-hotspots.mjs",
    "openapi:export": "TS_NODE_PROJECT=apps/api/tsconfig.app.json node -r ts-node/register -r tsconfig-paths/register apps/api/src/app/swagger/export-openapi.ts",
    "openapi:lint": "npx @redocly/cli lint --config .redocly.yaml apps/api/openapi/khana.v1.json",
    "openapi:check": "npm run openapi:export && npm run openapi:lint",
    "openapi:generate": "npm run openapi:check && npm exec --yes --package=orval@6.14.1 -- orval --config orval.config.cjs",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:build": "nx affected -t build",
    "clean": "nx reset && rimraf dist",
    "typeorm": "TS_NODE_PROJECT=apps/api/tsconfig.app.json node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d apps/api/src/typeorm/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "gen:lib": "nx g @nx/js:lib",
    "gen:nest-app": "nx g @nx/nest:app",
    "gen:angular-app": "nx g @nx/angular:app",
    "prepare": "husky",
    "i18n:extract": "ngx-translate-extract --input ./apps/manager-dashboard/src/app --output ./apps/manager-dashboard/public/assets/i18n/en.json ./apps/manager-dashboard/public/assets/i18n/ar.json --clean --sort --format namespaced-json"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,scss,css}": [
      "prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~20.3.0",
    "@angular-devkit/schematics": "~20.3.0",
    "@angular/build": "~20.3.0",
    "@angular/cli": "~20.3.0",
    "@angular/compiler-cli": "~20.3.0",
    "@angular/language-service": "~20.3.0",
    "@biesbjerg/ngx-translate-extract": "^7.0.4",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "^22.1.3",
    "@nx/devkit": "22.1.3",
    "@nx/eslint": "22.1.3",
    "@nx/eslint-plugin": "22.1.3",
    "@nx/jest": "22.1.3",
    "@nx/js": "22.5.0",
    "@nx/nest": "^22.1.3",
    "@nx/node": "22.1.3",
    "@nx/playwright": "22.1.3",
    "@nx/web": "22.5.0",
    "@nx/webpack": "22.1.3",
    "@nx/workspace": "22.1.3",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~20.3.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^7.0.9",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^20.3.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^30.0.2",
    "jest-environment-node": "29.7.0",
    "jest-preset-angular": "~14.6.1",
    "jest-util": "^30.0.2",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^15.5.2",
    "nx": "22.1.3",
    "orval": "6.14.1",
    "prettier": "~3.6.2",
    "@redocly/cli": "^2.5.1",
    "rimraf": "^5.0.10",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@angular/common": "~20.3.0",
    "@angular/compiler": "~20.3.0",
    "@angular/core": "~20.3.0",
    "@angular/forms": "~20.3.0",
    "@angular/platform-browser": "~20.3.0",
    "@angular/platform-browser-dynamic": "~20.3.0",
    "@angular/router": "~20.3.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@ngrx/signals": "^20.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ms": "^2.1.3",
    "nodemailer": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "zod": "^3.25.76",
    "zone.js": "~0.15.0"
  }
}
